# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit it.
#
# SUPABASE_SERVICE_KEY: service_role key from Supabase dashboard → Settings → API
# Required for npm run backup / npm run restore to export all users' data.
# Without it, the scripts fall back to the anon key and RLS blocks all rows.

SUPABASE_SERVICE_KEY=your_service_role_key_here
