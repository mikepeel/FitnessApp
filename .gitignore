# dependencies
node_modules/

# production build
build/

# backup exports — never commit user data
backups/

# environment variables — never commit real keys
# SUPABASE_SERVICE_KEY goes in .env (ignored below), not in code
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# playwright auth state — contains session tokens, never commit
tests/.auth/
playwright-report/
test-results/

# playwright MCP session logs and screenshots (dev tool only)
.playwright-mcp/

# Claude Code project settings (local only)
.claude/

# loose screenshots from manual testing
*.png

# design mockups & QA scratch notes (local working files, not part of the app)
mockup-*.html
qa-audit-findings*.md

# misc
.DS_Store
npm-debug.log*
yarn-debug.log*
yarn-error.log*
